{
  "name": "dadbuds",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "VITE_FULL_APP=false VITE_SHADOW_MODE=false vite",
    "dev:app": "VITE_FULL_APP=true VITE_SHADOW_MODE=false vite",
    "dev:shadow": "VITE_API_URL=http://127.0.0.1:8011 VITE_SHADOW_MODE=true vite --host 127.0.0.1 --port 5176",
    "api:shadow": "DATABASE_URL=sqlite:///backend/dadbuds-shadow.db SHADOW_MODE=true .venv/bin/uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8011",
    "seed:shadow": ".venv/bin/python scripts/seed_shadow_db.py",
    "ingest": ".venv/bin/python scripts/ingest_events.py",
    "build": "npm run build:landing",
    "build:app": "tsc -b && vite build",
    "build:landing": "VITE_FULL_APP=false VITE_SHADOW_MODE=false npm run build:app",
    "build:shadow": "DADBUDS_DEPLOY_TARGET=shadow node scripts/check-deploy-env.mjs && VITE_FULL_APP=true VITE_SHADOW_MODE=true npm run build:app",
    "build:prod-app": "DADBUDS_DEPLOY_TARGET=prod-app node scripts/check-deploy-env.mjs && VITE_FULL_APP=true VITE_SHADOW_MODE=false npm run build:app",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push scripts/pre-push-guard.sh",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.0.0",
    "typescript": "^5.8.0"
  }
}
