VITE_API_URL=http://localhost:8000
# Keep false/empty on the public landing deploy. Set true only when intentionally
# exposing the full app shell and internal routes.
VITE_FULL_APP=false
# Set APP_ENV=production on deployed API instances.
APP_ENV=development
APP_BASE_URL=http://localhost:5173
DATABASE_URL=sqlite:///backend/dadbuds.db
# Use a generated 32+ character token. Do not expose this as a VITE_* value.
ADMIN_TOKEN=replace-with-a-long-random-admin-token
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Keep false in production unless the API is bound to localhost only.
ALLOW_LOCAL_CORS=false
# Keep false in production. Email-only profile restore is not real auth.
ALLOW_INSECURE_EMAIL_SIGNIN=false
# Keep false in production. Internal user/social API paths currently need
# server-verified sessions before public exposure.
ALLOW_INSECURE_INTERNAL_FEATURES=false
# Keep false in production. Production should use managed Postgres with TLS.
ALLOW_SQLITE_IN_PRODUCTION=false
AUTH_LINK_MINUTES=15
AUTH_SESSION_DAYS=30
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SHADOW_MODE=false
VITE_SHADOW_MODE=false
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
INGEST_LOOKAHEAD_DAYS=90
